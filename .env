# ─── MongoDB ────────────────────────────────────────────
DB_user=your_mongodb_user
DB_PASS=your_mongodb_password

# ─── SSLCommerz Sandbox ─────────────────────────────────
# Get these from https://developer.sslcommerz.com/
# Replace with your actual sandbox Store ID and Store Password
SSL_STORE_ID=your_ssl_store_id
SSL_STORE_PASS=your_ssl_store_password

# Frontend URL (used for SSLCommerz redirect URLs)
FRONTEND_URL=http://localhost:5173

# ─── SMS / OTP (Twilio) ──────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ─── Email OTP (Resend) ──────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
EMAIL_FROM=AgroMart <no-reply@your-domain.com>
