# Existing server/database configuration
DB_user=your_mongodb_user
DB_PASS=your_mongodb_password

# Real SMS OTP delivery (required for payment mobile verification)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Optional email OTP delivery (SMS remains the required channel)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
EMAIL_FROM=AgroMart <no-reply@your-domain.com>
